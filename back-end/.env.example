# =============================================================================
# Copie este arquivo para ".env" e preencha com os valores do seu projeto.
#   cp .env.example .env
# =============================================================================

# --- Aplicacao -------------------------------------------------------------
APP_NAME=FIFA League API
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# --- Banco de dados (Supabase Postgres) ------------------------------------
# Pegue a connection string em: Supabase > Project Settings > Database.
# Use o driver asyncpg no inicio da URL: postgresql+asyncpg://
#
# Opcao A) Conexao direta (porta 5432):
#   DATABASE_URL=postgresql+asyncpg://postgres:SUA_SENHA@db.SEU_PROJECT_REF.supabase.co:5432/postgres
#
# Opcao B) Pooler transacional (porta 6543, recomendado p/ apps com muitas
#          conexoes / serverless). Requer DB_STATEMENT_CACHE_SIZE=0.
#   DATABASE_URL=postgresql+asyncpg://postgres.SEU_PROJECT_REF:SUA_SENHA@aws-0-SUA_REGIAO.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://postgres:SUA_SENHA@db.SEU_PROJECT_REF.supabase.co:5432/postgres

# Loga todas as queries SQL (util em dev, deixe false em producao)
DB_ECHO=false
# Supabase exige SSL
DB_USE_SSL=true
# Em redes com proxy corporativo, use false se aparecer CERTIFICATE_VERIFY_FAILED.
# Em producao, deixe true.
DB_SSL_VERIFY=true
# 0 desativa o cache de prepared statements do asyncpg.
# OBRIGATORIO ser 0 quando usar o pooler transacional (porta 6543).
DB_STATEMENT_CACHE_SIZE=0

# --- Supabase Auth (Admin API) ---------------------------------------------
# Pegue em: Supabase > Project Settings > API Keys
# SUPABASE_URL = Project URL
# SUPABASE_SERVICE_ROLE_KEY = service_role (JWT eyJ...) — NUNCA no front-end
# Obs.: o SDK Python atual exige JWT; nao use sb_secret_...
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.sua_service_role_key

# --- CORS ------------------------------------------------------------------
# Lista em formato JSON com as origens permitidas.
BACKEND_CORS_ORIGINS=["http://localhost:3000"]
